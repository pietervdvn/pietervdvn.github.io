module.exports={wikipedialink:{render:"<a href='https://wikipedia.org/wiki/{wikipedia}' target='_blank'><img src='./assets/svg/wikipedia.svg' alt='WP'/></a>",condition:"wikipedia~*",mappings:[{if:{and:["wikipedia=","wikidata~*"]},then:"<a href='https://www.wikidata.org/wiki/{wikidata}' target='_blank'><img src='./assets/svg/wikidata.svg' alt='WD'/></a>"}]},phonelink:{render:"<a href='tel:{phone}'><img src='./assets/svg/phone.svg'/></a>",condition:"phone~*"},emaillink:{render:"<a href='mailto:{email}'><img src='./assets/svg/send_email.svg'/></a>",condition:"email~*"},osmlink:{render:"<a href='https://openstreetmap.org/{id}' target='_blank'><img src='./assets/svg/osm-logo-us.svg'/></a>",mappings:[{if:"id~=-",then:"<span class='alert'>Uploading...</alert>"}]},sharelink:{render:"{share_link()}"}};